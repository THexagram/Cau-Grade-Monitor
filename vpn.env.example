CAU_VPN_SERVER=vpn.cau.edu.cn
CAU_VPN_PORT=443
CAU_VPN_USERNAME=
CAU_VPN_PASSWORD=
CAU_VPN_SOCKS_BIND=127.0.0.1:1080
CAU_VPN_RESOLVE=newjw.cau.edu.cn=10.200.36.235

# Optional: set this when EasierConnect.exe is not next to this monitor folder
# and is not in a sibling NJUConnect-rebuild-windows-x64-cau-dns folder.
CAU_VPN_EXE=

# Set true only if the VPN needs interactive SMS/TOTP input or you want to see VPN logs.
CAU_VPN_SHOW_WINDOW=false

# Automatically establish a fresh VPN session before the server-side session expires.
# Set 0 to disable scheduled reconnection.
CAU_VPN_RESTART_MINUTES=120

# Restart early when the EasierConnect tunnel log repeatedly reports EOF.
# This reads the local log only and does not send extra keepalive requests. Set 0 to disable.
CAU_VPN_EOF_RESTART_COUNT=4

# Lightweight local supervisor settings.
CAU_VPN_SUPERVISOR_INTERVAL_SECONDS=30
CAU_VPN_RETRY_SECONDS=30
CAU_VPN_START_TIMEOUT_SECONDS=60

# Optional monitor config file. Leave empty to use config.json.
CAU_MONITOR_CONFIG=
