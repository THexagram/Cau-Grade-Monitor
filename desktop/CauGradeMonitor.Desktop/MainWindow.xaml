<Window x:Class="CauGradeMonitor.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CAU 成绩守望" Height="760" Width="1160" MinHeight="660" MinWidth="980"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBackgroundBrush}">
    <Window.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="12,3" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Foreground" Value="#C9D2CC" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="NavBorder" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavBorder" Property="Background" Value="#26342C" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,5" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <Style x:Key="MetricValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,6,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="208" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="82" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="94" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="22,20,16,0">
                    <TextBlock Text="CAU 成绩守望" Foreground="White" FontSize="18" FontWeight="SemiBold" />
                    <TextBlock Text="VPN + 成绩监控" Foreground="#91A097" FontSize="12" Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="0,10,0,0">
                    <Button x:Name="DashboardNav" Style="{StaticResource NavButton}" Click="Navigate_Click" Tag="Dashboard" Background="#2B4335" Foreground="White">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE80F;" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" FontSize="16" Width="28" />
                            <TextBlock Text="总览" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="GradesNav" Style="{StaticResource NavButton}" Click="Navigate_Click" Tag="Grades">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE9D2;" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" FontSize="16" Width="28" />
                            <TextBlock Text="全部成绩" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="SettingsNav" Style="{StaticResource NavButton}" Click="Navigate_Click" Tag="Settings">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE713;" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" FontSize="16" Width="28" />
                            <TextBlock Text="设置" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="LogsNav" Style="{StaticResource NavButton}" Click="Navigate_Click" Tag="Logs">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xF000;" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" FontSize="16" Width="28" />
                            <TextBlock Text="运行日志" Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="22,0,16,18" VerticalAlignment="Bottom">
                    <TextBlock Text="数据保存在本机" Foreground="#91A097" FontSize="11" />
                    <TextBlock x:Name="SidebarVersionText" Text="v1.1" Foreground="#91A097" FontSize="11" Margin="0,4,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="68" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="26,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="PageTitleText" Text="运行总览" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock x:Name="PageSubtitleText" Text="查看连接、成绩与通知状态" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="VpnHeaderDot" Width="8" Height="8" Fill="#98A19B" Margin="0,0,7,0" />
                        <TextBlock x:Name="VpnHeaderText" Text="VPN 未连接" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                        <Border Width="1" Height="20" Background="{StaticResource BorderBrush}" Margin="16,0" />
                        <Ellipse x:Name="MonitorHeaderDot" Width="8" Height="8" Fill="#98A19B" Margin="0,0,7,0" />
                        <TextBlock x:Name="MonitorHeaderText" Text="监控未运行" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26,22,26,24">
                <Grid x:Name="DashboardPanel">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="StartButton" Grid.Column="0" Style="{StaticResource PrimaryButton}" Click="StartButton_Click" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE768;" Foreground="White" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="启动全部" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="StopButton" Grid.Column="1" Click="StopButton_Click" IsEnabled="False" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE71A;" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="停止" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Click="OpenDataFolder_Click" ToolTip="打开配置、状态与日志目录">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8B7;" FontSize="14" Margin="0,0,8,0" />
                                <TextBlock Text="数据目录" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="ActionStatusText" Grid.Column="4" Text="设置会自动保存" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="当前成绩" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock x:Name="CoursesMetricText" Text="--" Style="{StaticResource MetricValue}" />
                                <TextBlock Text="科" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="GpaScopeMetricLabel" Text="必修及体育绩点" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock x:Name="GpaMetricText" Text="--" Style="{StaticResource MetricValue}" Foreground="{StaticResource AccentBrush}" />
                                <TextBlock Text="按学分加权" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="计入绩点" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock x:Name="RequiredMetricText" Text="--" Style="{StaticResource MetricValue}" />
                                <TextBlock x:Name="CreditsMetricText" Text="-- 学分" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>
                        <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="18">
                            <StackPanel>
                                <TextBlock Text="最后查询" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                                <TextBlock x:Name="LastCheckMetricText" Text="--:--" Style="{StaticResource MetricValue}" FontSize="22" />
                                <TextBlock x:Name="SourceMetricText" Text="等待首次查询" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.08*" />
                            <ColumnDefinition Width="1.92*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="服务状态" Style="{StaticResource SectionTitle}" />
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="VpnBodyDot" Width="10" Height="10" Fill="#98A19B" VerticalAlignment="Top" Margin="0,5,0,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="校园 VPN" FontWeight="SemiBold" />
                                        <TextBlock x:Name="VpnBodyText" Text="未连接" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
                                        <TextBlock x:Name="VpnSinceText" Text="--" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="20" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Ellipse x:Name="MonitorBodyDot" Width="10" Height="10" Fill="#98A19B" VerticalAlignment="Top" Margin="0,5,0,0" />
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="成绩监控" FontWeight="SemiBold" />
                                        <TextBlock x:Name="MonitorBodyText" Text="未运行" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" />
                                        <TextBlock x:Name="NextCheckText" Text="查询间隔：60 秒" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                                <Separator Background="{StaticResource BorderBrush}" Margin="0,0,0,15" />
                                <TextBlock Text="浏览器登录状态会保存在独立目录，重启程序后继续使用。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="最近活动" Style="{StaticResource SectionTitle}" />
                                    <Button Grid.Column="1" Content="查看全部" Click="ShowLogs_Click" MinHeight="28" Padding="10,4" />
                                </Grid>
                                <TextBox x:Name="RecentLogText" Grid.Row="1" IsReadOnly="True" IsUndoEnabled="False" UndoLimit="0" TextWrapping="Wrap" AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto" Background="#F8FAF9" BorderThickness="0" Padding="12"
                                         FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI" FontSize="12" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Grid x:Name="GradesPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="GradesSummaryText" Text="等待首次成功查询" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Button x:Name="RefreshGpaButton" Grid.Column="1" Style="{StaticResource PrimaryButton}"
                                Click="RefreshGpa_Click" IsEnabled="False" MinHeight="30" Padding="11,5" Margin="0,0,12,0"
                                ToolTip="保存当前选择并立即重新计算绩点，无需重启监控">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE72C;" Foreground="White" FontSize="14" Margin="0,0,7,0" />
                                <TextBlock Text="刷新绩点" Foreground="White" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="GradesUpdatedText" Grid.Column="2" Text="--" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                    </Grid>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6">
                        <DataGrid x:Name="GradesGrid" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" CanUserDeleteRows="False"
                                  CanUserReorderColumns="True" CanUserResizeColumns="True" CanUserSortColumns="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#E8ECE9"
                                  BorderThickness="0" RowHeaderWidth="0" AlternatingRowBackground="#F8FAF9"
                                  Background="White" FontFamily="Segoe UI, Microsoft YaHei UI" FontSize="13">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="学期" Binding="{Binding Term}" Width="135" />
                                <DataGridTextColumn Header="课程号" Binding="{Binding Code}" Width="120" />
                                <DataGridTextColumn Header="课程名" Binding="{Binding Name}" Width="*" MinWidth="180" />
                                <DataGridTextColumn Header="学分" Binding="{Binding Credit}" Width="70" />
                                <DataGridTextColumn Header="成绩" Binding="{Binding Score}" Width="80" />
                                <DataGridTextColumn Header="类型" Binding="{Binding Type}" Width="130" />
                                <DataGridTemplateColumn Header="计入绩点" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IncludedInGpa, Mode=OneWay}"
                                                      IsEnabled="{Binding GpaEligible}"
                                                      Click="GradeIncludeCheckBox_Click"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      ToolTip="单独加入或排除这门课程" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>

                <Grid x:Name="SettingsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                        <Grid Margin="0,0,8,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="VPN 连接" Style="{StaticResource SectionTitle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="服务器" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="VpnServerText" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="端口" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="VpnPortText" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="用户名" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="VpnUsernameText" />
                                        <TextBlock Text="密码" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <PasswordBox x:Name="VpnPasswordInput" />
                                        <TextBlock Text="SOCKS5 监听地址" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="SocksBindText" />
                                        <TextBlock Text="内网域名映射" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="ResolveRuleText" />
                                        <TextBlock Text="EasierConnect.exe" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="EasierPathText" />
                                            <Button Grid.Column="2" Content="浏览" Click="BrowseEasierConnect_Click" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="自动恢复" Style="{StaticResource SectionTitle}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="12" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="VPN 重连间隔（分钟）" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="RestartMinutesText" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="EOF 触发阈值" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="EofCountText" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="设置为 0 可关闭对应机制。成绩监控异常退出时始终自动恢复。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="成绩监控" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="查询间隔（秒）" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="PollIntervalText" />
                                        <TextBlock Text="计入绩点的课程类型" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <Grid>
                                            <ToggleButton x:Name="GpaTypesToggle" HorizontalContentAlignment="Stretch">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock x:Name="GpaTypesSummaryText" Text="成功查询后加载类型" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                                    <TextBlock Grid.Column="1" FontFamily="Segoe Fluent Icons" Text="&#xE70D;" Foreground="{StaticResource MutedTextBrush}" Margin="10,0,0,0" VerticalAlignment="Center" />
                                                </Grid>
                                            </ToggleButton>
                                            <Popup PlacementTarget="{Binding ElementName=GpaTypesToggle}" Placement="Bottom" VerticalOffset="4"
                                                   IsOpen="{Binding IsChecked, ElementName=GpaTypesToggle, Mode=TwoWay}"
                                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                                <Border Width="{Binding ActualWidth, ElementName=GpaTypesToggle}" MinWidth="280" MaxHeight="310"
                                                        Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                                                        CornerRadius="6" Padding="12">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock Text="选择参与 GPA 计算的类型" FontWeight="SemiBold" Margin="2,0,2,10" />
                                                        <ScrollViewer Grid.Row="1" MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                                            <StackPanel x:Name="GpaTypesList" />
                                                        </ScrollViewer>
                                                        <Grid Grid.Row="2" Margin="0,10,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="8" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="保存后重启生效" Foreground="{StaticResource MutedTextBrush}" FontSize="11" VerticalAlignment="Center" />
                                                            <Button Grid.Column="1" Content="清空" Click="ClearGpaTypes_Click" MinHeight="28" Padding="10,4" />
                                                            <Button Grid.Column="3" Content="全选" Click="SelectAllGpaTypes_Click" MinHeight="28" Padding="10,4" />
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </Popup>
                                        </Grid>
                                        <TextBlock Text="统一身份认证入口" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="LoginUrlText" />
                                        <TextBlock Text="成绩页面" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="GradeUrlText" />
                                        <TextBlock Text="成绩查询接口" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <TextBox x:Name="ListUrlText" />
                                    </StackPanel>
                                </Border>

                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="飞书通知" Style="{StaticResource SectionTitle}" />
                                        <TextBlock Text="机器人 Webhook" Style="{StaticResource FieldLabel}" />
                                        <PasswordBox x:Name="FeishuWebhookInput" />
                                        <TextBlock Text="签名密钥（可选）" Style="{StaticResource FieldLabel}" Margin="0,14,0,5" />
                                        <PasswordBox x:Name="FeishuSecretInput" />
                                        <WrapPanel Margin="0,14,0,0">
                                            <CheckBox x:Name="NotifyOnStartCheck" Content="启动时通知" Margin="0,0,20,0" />
                                            <CheckBox x:Name="FeishuAtAllCheck" Content="通知所有人" />
                                        </WrapPanel>
                                        <Button Content="发送测试消息" Click="TestFeishu_Click" HorizontalAlignment="Left" Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="记忆与启动" Style="{StaticResource SectionTitle}" />
                                        <CheckBox x:Name="RememberSecretsCheck" Content="使用 Windows 加密记住密码与飞书配置" Margin="0,0,0,12" />
                                        <CheckBox x:Name="AutoStartCheck" Content="打开软件后自动启动全部" Margin="0,0,0,12" />
                                        <CheckBox x:Name="MinimizeToTrayCheck" Content="关闭窗口时最小化到托盘" />
                                        <TextBlock Text="密码、Webhook 和签名密钥使用 Windows 当前用户加密；Edge 登录状态保存在独立浏览器目录。" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,14,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>

                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="SettingsStatusText" Text="修改后保存；运行中修改需要重新启动服务。" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButton}" Click="SaveSettings_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE74E;" Foreground="White" Margin="0,0,8,0" />
                                    <TextBlock Text="保存设置" Foreground="White" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>

                <Grid x:Name="LogsPanel" Visibility="Collapsed">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="最多显示最近 500 条，完整日志保存在本机。" Foreground="{StaticResource MutedTextBrush}" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="清空显示" Click="ClearLogs_Click" Margin="0,0,8,0" />
                        <Button Grid.Column="2" Content="打开日志目录" Click="OpenLogsFolder_Click" />
                    </Grid>
                    <Border Grid.Row="1" Background="White" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="0">
                        <TextBox x:Name="FullLogText" IsReadOnly="True" IsUndoEnabled="False" UndoLimit="0" TextWrapping="NoWrap" AcceptsReturn="True"
                                 HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" BorderThickness="0"
                                 Background="#101612" Foreground="#D6E0D9" Padding="16"
                                 FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI" FontSize="12" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
